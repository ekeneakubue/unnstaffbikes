generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  VERIFIER
}

enum ApplicantStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  firstname       String
  surname         String
  profilePhotoUrl String?
  role            UserRole @default(VERIFIER)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  verifiedApplicants Applicant[] @relation("VerifiedBy")
  parkedApplicants   Applicant[] @relation("ParkedBy")

  @@map("users")
}

model Faculty {
  id          String       @id @default(cuid())
  name        String       @unique
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  departments Department[]

  @@map("faculties")
}

model Department {
  id         String     @id @default(cuid())
  name       String     @unique
  facultyId  String
  faculty    Faculty    @relation(fields: [facultyId], references: [id], onDelete: Restrict)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  applicants Applicant[]

  @@index([facultyId])
  @@map("departments")
}

model Station {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stations")
}

model Applicant {
  id              String          @id @default(cuid())
  firstname       String
  surname         String
  phoneNumber     String
  staffNumber     String          @unique
  departmentId    String
  department      Department      @relation(fields: [departmentId], references: [id])
  stateOfOrigin   String
  localGovernment String
  motorcycleNo    String          @unique
  motorcycleMake  String
  engineNumber    String          @unique
  profilePhotoUrl String?
  status          ApplicantStatus @default(PENDING)
  verifiedAt      DateTime?
  verifiedById    String?
  verifiedBy      User?           @relation("VerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  isParked        Boolean         @default(false)
  parkedAt        DateTime?
  parkedById      String?
  parkedBy        User?           @relation("ParkedBy", fields: [parkedById], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([staffNumber])
  @@index([motorcycleNo])
  @@index([departmentId])
  @@map("applicants")
}
